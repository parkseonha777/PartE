# 이 파일을 복사해서 .env 로 만들고 실제 값 채워넣기
# .env는 절대 git에 커밋하지 말 것 (.gitignore에 등록되어 있는지 꼭 확인)

FOODSAFETY_API_KEY=여기에_발급받은_API_키_입력

# Supabase 프로젝트 설정 > Database > Connection string > URI 에서 복사
# [YOUR-PASSWORD] 부분을 프로젝트 생성 시 설정한 비밀번호로 교체할 것
DATABASE_URL=postgresql://postgres.프로젝트ID:비밀번호@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# 참고: Supabase 대시보드 URL (팀원 공유용)
SUPABASE_PROJECT_URL=https://프로젝트ID.supabase.co
SUPABASE_ANON_KEY=여기에_anon_public_키_입력
